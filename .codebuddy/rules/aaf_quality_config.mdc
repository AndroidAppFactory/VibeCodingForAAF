## Android质量检查规则

### android-quality-rules.json

```json
{
  "version": "1.0.0",
  "categories": {
    "architecture": {
      "enabled": true,
      "rules": {
        "layerViolation": {
          "enabled": true,
          "level": "warning",
          "description": "检查分层架构违规",
          "patterns": [
            "UI层直接访问数据层",
            "跨层级依赖调用"
          ]
        },
        "moduleDependency": {
          "enabled": true,
          "level": "error",
          "checkCircularDependency": true,
          "maxDependencyDepth": 5
        },
        "singletonPattern": {
          "enabled": true,
          "level": "info",
          "preferEnum": true,
          "threadSafety": true
        }
      }
    },
    "performance": {
      "enabled": true,
      "rules": {
        "mainThreadBlocking": {
          "enabled": true,
          "level": "error",
          "patterns": [
            "\\.execute\\(\\)",
            "Thread\\.sleep\\(",
            "synchronized.*long"
          ],
          "suggestions": ["使用异步处理", "使用协程"]
        },
        "memoryAllocation": {
          "enabled": true,
          "level": "warning",
          "checkLoopAllocation": true,
          "checkStringConcatenation": true
        },
        "viewHolderPattern": {
          "enabled": true,
          "level": "warning",
          "enforceInRecyclerView": true
        }
      }
    },
    "crashRisk": {
      "enabled": true,
      "rules": {
        "nullPointer": {
          "enabled": true,
          "level": "error",
          "checkNullableAccess": true,
          "requireNullChecks": true
        },
        "exceptionHandling": {
          "enabled": true,
          "level": "warning",
          "requireTryCatch": [
            "JSON解析",
            "网络请求", 
            "文件操作",
            "数据库操作"
          ]
        },
        "resourceLeaks": {
          "enabled": true,
          "level": "error",
          "checkStreamClosing": true,
          "checkCursorClosing": true
        }
      }
    },
    "memoryLeak": {
      "enabled": true,
      "rules": {
        "contextLeak": {
          "enabled": true,
          "level": "error",
          "patterns": [
            "static.*Context",
            "Handler.*Activity",
            "AsyncTask.*Activity"
          ]
        },
        "listenerLeak": {
          "enabled": true,
          "level": "warning",
          "checkLifecycleManagement": true,
          "requireUnregister": true
        },
        "innerClassLeak": {
          "enabled": true,
          "level": "warning",
          "preferStaticInnerClass": true
        }
      }
    }
  },
  "metrics": {
    "complexity": {
      "methodComplexity": {
        "threshold": 10,
        "level": "warning"
      },
      "classComplexity": {
        "threshold": 50,
        "level": "info"
      }
    },
    "size": {
      "methodLength": {
        "threshold": 50,
        "level": "info"
      },
      "classLength": {
        "threshold": 500,
        "level": "warning"
      }
    }
  }
}
```

## 接口设计原则规则

### interface-design-rules.json

```json
{
  "version": "1.0.0",
  "baseReference": "https://blog.bihe0832.com/principles.html",
  "principles": {
    "singleResponsibility": {
      "enabled": true,
      "level": "warning",
      "description": "单一职责原则 - 一个类应该只有一个引起它变化的原因",
      "checks": {
        "methodCount": {
          "threshold": 20,
          "suggestion": "考虑拆分类职责"
        },
        "responsibilityMixing": {
          "patterns": [
            "数据访问与业务逻辑混合",
            "UI逻辑与数据处理混合"
          ]
        }
      }
    },
    "openClosed": {
      "enabled": true,
      "level": "info",
      "description": "开闭原则 - 对扩展开放，对修改关闭",
      "checks": {
        "extensibility": {
          "preferInterfaces": true,
          "avoidFinalClasses": true
        },
        "modification": {
          "checkFrequentChanges": true,
          "suggestAbstraction": true
        }
      }
    },
    "liskovSubstitution": {
      "enabled": true,
      "level": "error",
      "description": "里氏替换原则 - 子类必须能够替换其基类",
      "checks": {
        "contractViolation": {
          "checkPreconditions": true,
          "checkPostconditions": true
        },
        "behaviorChange": {
          "checkExceptionChanges": true,
          "checkReturnTypeChanges": true
        }
      }
    },
    "interfaceSegregation": {
      "enabled": true,
      "level": "warning",
      "description": "接口隔离原则 - 客户端不应该依赖它不需要的接口",
      "checks": {
        "interfaceSize": {
          "maxMethods": 10,
          "suggestion": "考虑拆分接口"
        },
        "clientUsage": {
          "checkUnusedMethods": true,
          "suggestSplitting": true
        }
      }
    },
    "dependencyInversion": {
      "enabled": true,
      "level": "warning",
      "description": "依赖倒置原则 - 高层模块不应该依赖低层模块",
      "checks": {
        "abstractionDependency": {
          "preferInterfaces": true,
          "avoidConcreteClasses": true
        },
        "dependencyDirection": {
          "checkLayerViolation": true,
          "suggestInjection": true
        }
      }
    },
    "demeter": {
      "enabled": true,
      "level": "info",
      "description": "迪米特法则 - 一个对象应该对其他对象有最少的了解",
      "checks": {
        "methodChaining": {
          "maxChainLength": 3,
          "suggestion": "避免过长的方法链"
        },
        "friendClasses": {
          "limitFriendship": true,
          "checkCoupling": true
        }
      }
    }
  },
  "autoFix": {
    "enabled": false,
    "reason": "设计原则问题通常需要人工判断和重构"
  },
  "suggestions": {
    "singleResponsibility": [
      "将不同职责的方法提取到不同的类中",
      "使用组合模式替代继承",
      "考虑使用策略模式分离算法"
    ],
    "openClosed": [
      "使用抽象类或接口定义扩展点",
      "应用模板方法模式",
      "考虑使用装饰器模式"
    ],
    "liskovSubstitution": [
      "确保子类不改变父类的行为契约",
      "避免在子类中抛出新的异常",
      "保持方法签名的兼容性"
    ],
    "interfaceSegregation": [
      "将大接口拆分为多个小接口",
      "使用适配器模式处理接口不匹配",
      "考虑使用组合替代继承"
    ],
    "dependencyInversion": [
      "使用依赖注入框架",
      "定义抽象接口隔离具体实现",
      "应用工厂模式创建对象"
    ],
    "demeter": [
      "减少对象间的直接交互",
      "使用中介者模式",
      "封装对象的内部结构"
    ]
  }
}
```

## AAF框架使用规则

### aaf-framework-rules.json

```json
{
  "version": "1.0.0",
  "frameworkModules": {
    "LibNetwork": {
      "description": "网络请求管理",
      "replaces": ["OkHttp", "Retrofit", "Volley"],
      "usage": "LibNetwork.getInstance().doGet(url, callback)",
      "level": "warning"
    },
    "LibFile": {
      "description": "文件操作工具",
      "replaces": ["自定义文件工具", "Apache Commons IO"],
      "usage": "LibFile.copyFile(src, dst)",
      "level": "info"
    },
    "LibThread": {
      "description": "线程管理",
      "replaces": ["Thread", "AsyncTask", "Executor"],
      "usage": "LibThread.getInstance().runOnBackgroundThread(task)",
      "level": "warning"
    },
    "LibImage": {
      "description": "图片处理",
      "replaces": ["Glide", "Picasso", "Fresco"],
      "usage": "LibImage.loadImage(url, imageView)",
      "level": "info"
    },
    "LibDownload": {
      "description": "下载管理",
      "replaces": ["DownloadManager", "自定义下载"],
      "usage": "LibDownload.download(url, path, callback)",
      "level": "warning"
    }
  },
  "detectionRules": {
    "networkLibraries": {
      "patterns": [
        "import.*okhttp3",
        "import.*retrofit2",
        "import.*volley",
        "OkHttpClient",
        "Retrofit\\.Builder"
      ],
      "suggestion": "使用AAF LibNetwork替代第三方网络库",
      "autoFix": false
    },
    "threadManagement": {
      "patterns": [
        "new Thread\\(",
        "AsyncTask",
        "Executors\\.",
        "ThreadPoolExecutor"
      ],
      "suggestion": "使用AAF LibThread进行线程管理",
      "autoFix": false
    },
    "fileOperations": {
      "patterns": [
        "Files\\.copy",
        "FileUtils\\.",
        "IOUtils\\."
      ],
      "suggestion": "使用AAF LibFile进行文件操作",
      "autoFix": false
    }
  },
  "versionCheck": {
    "enabled": true,
    "aafVersionSource": "../AndroidAppFactory/dependencies.gradle",
    "checkFrequency": "daily",
    "rules": {
      "outdatedVersion": {
        "level": "warning",
        "threshold": "1.0.0",
        "suggestion": "升级到最新AAF版本"
      },
      "betaVersion": {
        "level": "info",
        "allowInProduction": false
      }
    }
  },
  "usageAnalytics": {
    "enabled": true,
    "trackUsageRate": true,
    "generateReports": true,
    "metrics": {
      "aafUsageRate": {
        "target": 0.8,
        "level": "info"
      },
      "thirdPartyDependencies": {
        "maxCount": 10,
        "level": "warning"
      }
    }
  }
}
```

## AAF架构规范规则

### aaf-architecture-rules.json

```json
{
  "version": "1.0.0",
  "dependencyManagement": {
    "enabled": true,
    "rules": {
      "centralizedDependencies": {
        "enabled": true,
        "level": "error",
