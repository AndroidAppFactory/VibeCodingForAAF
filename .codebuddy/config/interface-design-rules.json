{
  "version": "1.0.0",
  "baseReference": "https://blog.bihe0832.com/principles.html",
  "principles": {
    "singleResponsibility": {
      "enabled": true,
      "level": "warning",
      "description": "单一职责原则 - 一个类应该只有一个引起它变化的原因",
      "checks": {
        "methodCount": {
          "threshold": 20,
          "suggestion": "考虑拆分类职责"
        },
        "responsibilityMixing": {
          "patterns": [
            "数据访问与业务逻辑混合",
            "UI逻辑与数据处理混合"
          ]
        }
      }
    },
    "openClosed": {
      "enabled": true,
      "level": "info",
      "description": "开闭原则 - 对扩展开放，对修改关闭",
      "checks": {
        "extensibility": {
          "preferInterfaces": true,
          "avoidFinalClasses": true
        }
      }
    },
    "liskovSubstitution": {
      "enabled": true,
      "level": "error",
      "description": "里氏替换原则 - 子类必须能够替换其基类",
      "checks": {
        "contractViolation": {
          "checkPreconditions": true,
          "checkPostconditions": true
        }
      }
    },
    "interfaceSegregation": {
      "enabled": true,
      "level": "warning",
      "description": "接口隔离原则 - 客户端不应该依赖它不需要的接口",
      "checks": {
        "interfaceSize": {
          "maxMethods": 10,
          "suggestion": "考虑拆分接口"
        }
      }
    },
    "dependencyInversion": {
      "enabled": true,
      "level": "warning",
      "description": "依赖倒置原则 - 高层模块不应该依赖低层模块",
      "checks": {
        "abstractionDependency": {
          "preferInterfaces": true,
          "avoidConcreteClasses": true
        }
      }
    },
    "demeter": {
      "enabled": true,
      "level": "info",
      "description": "迪米特法则 - 一个对象应该对其他对象有最少的了解",
      "checks": {
        "methodChaining": {
          "maxChainLength": 3,
          "suggestion": "避免过长的方法链"
        }
      }
    }
  },
  "autoFix": {
    "enabled": false,
    "reason": "设计原则问题通常需要人工判断和重构"
  }
}