{
  "version": "1.0.0",
  "dependencyManagement": {
    "enabled": true,
    "rules": {
      "centralizedDependencies": {
        "enabled": true,
        "level": "error",
        "description": "所有依赖必须在根目录dependencies_*.gradle中管理",
        "configFiles": [
          "config.gradle",
          "dependencies.gradle",
          "dependencies_lib.gradle",
          "dependencies_common.gradle"
        ],
        "forbiddenLocations": [
          "*/build.gradle",
          "*/app/build.gradle"
        ]
      },
      "dependencyFormat": {
        "enabled": true,
        "level": "warning",
        "requiredFormat": "implementation deps.moduleName",
        "forbiddenFormat": "implementation 'group:artifact:version'"
      },
      "circularDependency": {
        "enabled": true,
        "level": "error",
        "checkGradleModules": true
      }
    }
  },
  "versionManagement": {
    "enabled": true,
    "rules": {
      "aafVersionConsistency": {
        "enabled": true,
        "level": "warning",
        "description": "检查AAF模块版本是否与框架实际版本一致（注意：不同模块可能有不同版本，这是正常的）"
      },
      "outdatedDependencies": {
        "enabled": true,
        "level": "warning",
        "autoUpdate": false
      }
    }
  },
  "moduleStructure": {
    "enabled": true,
    "rules": {
      "namingConvention": {
        "enabled": true,
        "level": "warning",
        "modulePrefix": "Lib",
        "examples": ["LibNetwork", "LibFile", "LibThread"]
      },
      "packageStructure": {
        "enabled": true,
        "level": "info",
        "basePackage": "com.bihe0832",
        "enforceConsistency": true
      }
    }
  },
  "buildConfiguration": {
    "enabled": true,
    "rules": {
      "gradleVersion": {
        "enabled": true,
        "level": "warning",
        "minVersion": "7.0.0"
      },
      "kotlinVersion": {
        "enabled": true,
        "level": "warning"
      },
      "compileSdkVersion": {
        "enabled": true,
        "level": "info"
      }
    }
  }
}